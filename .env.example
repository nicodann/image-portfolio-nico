# Cloudinary — find these in your Cloudinary dashboard
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# GitHub — used to commit updated artwork.json after each upload
# GITHUB_TOKEN must be a fine-grained personal access token scoped to ONLY this
# repository with ONLY "Contents: write" permission.
# Do NOT use a classic token with broad repo access.
GITHUB_TOKEN=
GITHUB_REPO=owner/repo
GITHUB_BRANCH=main
